import type { ReactNode } from "react"

type LegalDocumentSection = {
  heading: string
  body?: string[]
  bullets?: string[]
}

type LegalDocumentData = {
  title: string
  eyebrow?: string
  updated?: string
  intro?: string | string[]
  sections: LegalDocumentSection[]
  note?: string
}

export function LegalDocumentView({
  document,
  modal = false,
}: {
  document: LegalDocumentData
  modal?: boolean
}) {
  const introItems = Array.isArray(document.intro)
    ? document.intro
    : document.intro
      ? [document.intro]
      : []

  return (
    <article
      className={
        modal
          ? "legal-document legal-document-modal"
          : "legal-document legal-document-page"
      }
    >
      <div className="legal-document-header">
        {document.eyebrow ? (
          <div className="legal-document-eyebrow">{document.eyebrow}</div>
        ) : null}

        <h1>{document.title}</h1>

        {document.updated ? (
          <div className="legal-document-updated">
            Last updated: {document.updated}
          </div>
        ) : null}

        {introItems.length > 0 ? (
          <div className="legal-document-intro">
            {introItems.map((item, index) => (
              <p key={`intro-${index}`}>{item}</p>
            ))}
          </div>
        ) : null}
      </div>

      <div className="legal-document-content">
        {document.sections.map((section, index) => (
          <section className="legal-document-section" key={section.heading}>
            <div className="legal-document-section-number">
              {String(index + 1).padStart(2, "0")}
            </div>

            <div className="legal-document-section-body">
              <h2>{section.heading}</h2>

              {section.body?.map((paragraph, paragraphIndex) => (
                <p key={`${section.heading}-p-${paragraphIndex}`}>
                  {paragraph}
                </p>
              ))}

              {section.bullets && section.bullets.length > 0 ? (
                <ul>
                  {section.bullets.map((item, bulletIndex) => (
                    <li key={`${section.heading}-li-${bulletIndex}`}>
                      {item}
                    </li>
                  ))}
                </ul>
              ) : null}
            </div>
          </section>
        ))}
      </div>

      {document.note ? (
        <div className="legal-document-note">{document.note}</div>
      ) : null}

      <style jsx>{`
        .legal-document {
          width: 100%;
          color: #0e1b35;
        }

        .legal-document-page {
          max-width: 900px;
          margin: 0 auto;
        }

        .legal-document-modal {
          max-width: 820px;
          margin: 0 auto;
        }

        .legal-document-header {
          padding-bottom: 28px;
          border-bottom: 1px solid #e2e6f0;
        }

        .legal-document-eyebrow {
          margin-bottom: 12px;
          color: #7c3aed;
          font-size: 11px;
          font-weight: 900;
          letter-spacing: 0.16em;
          text-transform: uppercase;
        }

        .legal-document h1 {
          margin: 0;
          font-family: "DM Serif Display", Georgia, serif;
          font-size: ${modal ? "34px" : "46px"};
          line-height: 1.08;
          font-weight: 400;
          letter-spacing: -0.045em;
          color: #0e1b35;
        }

        .legal-document-updated {
          margin-top: 12px;
          color: #94a3b8;
          font-size: 13px;
          font-weight: 700;
        }

        .legal-document-intro {
          margin-top: 22px;
          display: grid;
          gap: 12px;
        }

        .legal-document-intro p {
          margin: 0;
          max-width: 760px;
          color: #475569;
          font-size: 15px;
          line-height: 1.85;
        }

        .legal-document-content {
          display: grid;
          gap: 0;
        }

        .legal-document-section {
          display: grid;
          grid-template-columns: 54px minmax(0, 1fr);
          gap: 18px;
          padding: 28px 0;
          border-bottom: 1px solid #e2e6f0;
        }

        .legal-document-section-number {
          padding-top: 3px;
          color: #c4b5fd;
          font-size: 13px;
          font-weight: 900;
          letter-spacing: 0.08em;
        }

        .legal-document-section-body h2 {
          margin: 0 0 10px;
          color: #0e1b35;
          font-size: 18px;
          line-height: 1.35;
          font-weight: 900;
          letter-spacing: -0.025em;
        }

        .legal-document-section-body p {
          margin: 0 0 12px;
          color: #475569;
          font-size: 14.5px;
          line-height: 1.85;
        }

        .legal-document-section-body p:last-child {
          margin-bottom: 0;
        }

        .legal-document-section ul {
          margin: 10px 0 0;
          padding-left: 20px;
        }

        .legal-document-section li {
          padding-left: 4px;
          margin-bottom: 8px;
          color: #475569;
          font-size: 14.5px;
          line-height: 1.85;
        }

        .legal-document-note {
          margin-top: 28px;
          padding: 18px 20px;
          border-left: 4px solid #7c3aed;
          background: linear-gradient(90deg, #f3f0ff 0%, #ffffff 100%);
          color: #5b21b6;
          font-size: 14px;
          line-height: 1.75;
          font-weight: 700;
        }

        @media (max-width: 640px) {
          .legal-document h1 {
            font-size: 32px;
          }

          .legal-document-section {
            grid-template-columns: 1fr;
            gap: 8px;
            padding: 24px 0;
          }

          .legal-document-section-number {
            padding-top: 0;
          }
        }
      `}</style>
    </article>
  )
}

export default LegalDocumentView
