generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

enum MBETrack {
  CLASSIC
  NEXTGEN

  @@schema("public")
}

enum MBESessionMode {
  STUDY
  QUIZ
  REVIEW

  @@schema("public")
}

enum QuestionStatus {
  ACTIVE
  DRAFT
  DISABLED
  FLAGGED

  @@schema("public")
}

model rules {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id                String?                   @db.Uuid
  subtopic_id             String?                   @db.Uuid
  title                   String
  rule_text               String
  prompt_question         String?
  explanation             String?
  application_example     String?
  how_to_apply           Json?
  common_traps           Json?
  exam_tip               String?
  common_trap             String?
  priority                String?
  buzzwords               Json?
  cloze_template          String?
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  subject_uuid            String?                   @db.Uuid
  subject_id              String?                   @db.Uuid
  rule_type               String?
  flashcard_session_cards flashcard_session_cards[]
  subjects                subjects?                 @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_rules_subject")
  subtopics               subtopics?                @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics                  topics?                   @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rule_progress      user_rule_progress[]
  user_rules              user_rules[]

  @@index([subtopic_id])
  @@index([topic_id])
  @@index([subject_id])
  @@schema("public")
}

model subjects {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  exam_status           String             @default("core")
  show_in_rule_training Boolean            @default(true)
  show_in_analytics     Boolean            @default(true)
  order_index           Int                @default(0)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  rules                 rules[]
  topics                topics[]
  mbe_questions         MBEQuestion[]
  topic_progress        TopicProgress[]
  user_subject_stats    UserSubjectStat[]
  state_subject_stats   StateSubjectStat[]

  @@schema("public")
}

model subtopics {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id      String        @db.Uuid
  name          String
  order_index   Int           @default(0)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  rules         rules[]
  topics        topics        @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rules    user_rules[]
  mbe_questions MBEQuestion[]

  @@index([topic_id])
  @@schema("public")
}

model topics {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String          @db.Uuid
  name           String
  order_index    Int             @default(0)
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  rules          rules[]
  subtopics      subtopics[]
  subjects       subjects        @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "topics_subject_fk")
  user_rules     user_rules[]
  mbe_questions  MBEQuestion[]
  topic_progress TopicProgress[]

  @@index([subject_id])
  @@schema("public")
}

model user_buzzword_stats {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  rule_id       String    @db.Uuid
  buzzword      String
  times_correct Int?      @default(0)
  times_missed  Int?      @default(0)
  weak_flag     Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model user_rule_attempts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  rule_id          String    @db.Uuid
  score            Int
  training_mode    String?   @db.VarChar(50)
  missed_buzzwords Json?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([user_id, training_mode])
  @@schema("public")
}

model user_rule_progress {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  rule_id          String    @db.Uuid
  attempts         Int       @default(0)
  correct_count    Int       @default(0)
  incorrect_count  Int       @default(0)
  saved_for_review Boolean   @default(false)
  needs_practice   Boolean   @default(false)
  mastery_level    Int       @default(0)
  last_reviewed    DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  last_score       Int?
  rolling_average  Decimal?  @db.Decimal
  next_review_at   DateTime? @db.Timestamptz(6)
  interval_days    Int?      @default(1)
  rules            rules     @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, rule_id], map: "user_rule_progress_user_rule_unique")
  @@index([rule_id])
  @@index([user_id])
  @@index([user_id, next_review_at])
  @@schema("public")
}

model user_rules {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  original_rule_id    String    @db.Uuid
  topic_id            String    @db.Uuid
  subtopic_id         String    @db.Uuid
  title               String
  rule_text           String
  prompt_question     String?
  explanation         String?
  application_example String?
  how_to_apply       Json?
  common_traps       Json?
  exam_tip           String?
  common_trap         String?
  priority            String?
  buzzwords           Json?
  cloze_template      String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  subject_id          String?   @db.Uuid
  rules               rules     @relation(fields: [original_rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtopics           subtopics @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics              topics    @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([original_rule_id])
  @@index([subtopic_id])
  @@index([topic_id])
  @@index([user_id])
  @@schema("public")
}

model flashcard_sessions {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                    @db.Uuid
  mode          String
  timed         Boolean                   @default(false)
  time_per_card Int?
  card_count    Int
  started_at    DateTime                  @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?                 @db.Timestamptz(6)
  cards         flashcard_session_cards[]

  @@index([user_id])
  @@schema("public")
}

model flashcard_session_cards {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String             @db.Uuid
  rule_id        String?            @db.Uuid
  custom_rule_id String?            @db.Uuid
  position       Int
  result         String?
  time_spent     Int?
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  rules          rules?             @relation(fields: [rule_id], references: [id])
  session        flashcard_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([rule_id])
  @@schema("public")
}

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  mode            String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  mbeQuestions    Int       @default(0)
  ruleAttempts    Int       @default(0)
  flashcards      Int       @default(0)
  correctAnswers  Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([startedAt])
  @@index([userId, startedAt])
  @@schema("public")
}

model user {
  id           String   @id @default(cuid())
  jurisdiction String?
  createdAt    DateTime @default(now())

  @@schema("public")
}

model userRuleStat {
  id            String @id @default(cuid())
  userId        String
  ruleId        String
  attemptsTotal Int    @default(0)
  correct       Int    @default(0)
  incorrect     Int    @default(0)
  accuracy      Float?

  @@index([userId])
  @@index([ruleId])
  @@schema("public")
}

model user_mbe_attempts {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  session_id      String?  @db.Uuid
  question_id     String?  @db.Uuid
  selected_answer String?
  is_correct      Boolean
  time_spent_sec  Int?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  exam_session ExamSession? @relation(fields: [session_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  mbe_question MBEQuestion? @relation(fields: [question_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([session_id])
  @@index([question_id])
  @@schema("public")
}

model StudyPlan {
  id            String   @id @default(uuid())
  userId        String   @unique
  startDate     DateTime
  examDate      DateTime
  studyWeekends Boolean
  dailyMBE      Int
  dailyRules    Int
  totalDays     Int
  createdAt     DateTime @default(now())
  offDates      String[] @default([])

  @@schema("public")
}

model beta_invites {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  email      String   @unique
  law_school String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@schema("public")
}

model profiles {
  id                    String    @id @db.Uuid
  email                 String    @unique
  full_name             String?
  law_school            String?
  jurisdiction          String?
  exam_month            Int?
  exam_year             Int?
  phone_number          String?
  mbe_access            Boolean   @default(false)
  subscription_tier     String?   @default("free")
  role                  String    @default("user")
  admin_role            String?   @default("user")
  is_blocked            Boolean   @default(false)
  is_admin              Boolean   @default(false)
  email_announcements   Boolean   @default(true)
  study_reminders       Boolean   @default(true)
  sound_effects         Boolean   @default(false)
  compact_mode          Boolean   @default(false)
  pending_deletion      Boolean   @default(false)
  deletion_requested_at DateTime? @db.Timestamptz(6)
  deleted_at            DateTime? @db.Timestamptz(6)

  can_manage_questions     Boolean @default(false)
  can_manage_rules         Boolean @default(false)
  can_manage_users         Boolean @default(false)
  can_manage_announcements Boolean @default(false)
  can_view_billing         Boolean @default(false)
  can_manage_coupons       Boolean @default(false)
  can_manage_settings      Boolean @default(false)
  can_view_audit_log       Boolean @default(false)

  can_manage_workspace_members      Boolean @default(false)
  can_create_workspace_channels     Boolean @default(false)
  can_manage_workspace_channels     Boolean @default(false)
  can_manage_hidden_channels        Boolean @default(false)
  can_manage_workspace_notes        Boolean @default(false)
  can_create_shared_notes           Boolean @default(false)
  can_create_workspace_polls        Boolean @default(false)
  can_send_workspace_wake_alerts    Boolean @default(false)
  can_view_workspace_member_details Boolean @default(false)
  can_manage_all_workspace          Boolean @default(false)

  workspace_status String    @default("online")

  last_login_at        DateTime? @db.Timestamptz(6)
  last_active_at       DateTime? @db.Timestamptz(6)
  last_ip_address      String?
  last_country         String?
  last_region          String?
  last_city            String?
  last_timezone        String?
  last_latitude        Float?
  last_longitude       Float?
  last_user_agent      String?
  last_activity_source String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  @@index([jurisdiction])
  @@index([role])
  @@index([is_admin])
  @@index([is_blocked])
  @@schema("public")
}

model workspace_settings {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                          String   @unique @default("global")
  allow_note_creation           Boolean  @default(true)
  allow_shared_note_creation    Boolean  @default(true)
  allow_channel_creation        Boolean  @default(true)
  allow_hidden_channel_creation Boolean  @default(true)
  allow_poll_creation           Boolean  @default(true)
  allow_wake_alerts             Boolean  @default(true)
  created_at                    DateTime @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model MBEQuestion {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_number  Int?           @unique
  title            String?
  question_text    String
  answer_a         String
  answer_b         String
  answer_c         String
  answer_d         String
  correct_answer   String
  explanation      String?
  rule_text        String?
  subject_id       String         @db.Uuid
  topic_id         String?        @db.Uuid
  subtopic_id      String?        @db.Uuid
  track            MBETrack       @default(CLASSIC)
  difficulty       Int?           @default(1)
  source           String?
  source_reference String?
  question_status  QuestionStatus @default(ACTIVE)
  is_active        Boolean        @default(true)
  version          Int            @default(1)
  flagged_count    Int            @default(0)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @db.Timestamptz(6)

  subjects               subjects              @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  topics                 topics?               @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtopics              subtopics?            @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exam_session_questions ExamSessionQuestion[]
  user_mbe_attempts      user_mbe_attempts[]
  question_flags         QuestionFlag[]
  question_revisions     QuestionRevision[]

  @@index([subject_id])
  @@index([topic_id])
  @@index([subtopic_id])
  @@index([track])
  @@index([question_status])
  @@schema("public")
}

model ExamSession {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String         @db.Uuid
  track              MBETrack       @default(CLASSIC)
  mode               MBESessionMode
  review_source      String?
  total_questions    Int
  time_limit_seconds Int?
  started_at         DateTime       @default(now()) @db.Timestamptz(6)
  completed_at       DateTime?      @db.Timestamptz(6)
  is_completed       Boolean        @default(false)
  score              Float?
  correct_count      Int            @default(0)
  incorrect_count    Int            @default(0)
  unanswered_count   Int            @default(0)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)

  questions         ExamSessionQuestion[]
  user_mbe_attempts user_mbe_attempts[]

  @@index([user_id])
  @@index([track])
  @@index([mode])
  @@index([started_at])
  @@schema("public")
}

model ExamSessionQuestion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id  String   @db.Uuid
  question_id String   @db.Uuid
  order_index Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  exam_session ExamSession @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mbe_question MBEQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([session_id, question_id])
  @@index([session_id])
  @@index([question_id])
  @@index([order_index])
  @@schema("public")
}

model TopicProgress {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  subject_id     String    @db.Uuid
  topic_id       String    @db.Uuid
  solved_count   Int       @default(0)
  correct_count  Int       @default(0)
  accuracy       Float?    @default(0)
  last_attempted DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  subjects subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  topics   topics   @relation(fields: [topic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, topic_id])
  @@index([user_id])
  @@index([subject_id])
  @@index([topic_id])
  @@schema("public")
}

model UserSubjectStat {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String    @db.Uuid
  subject_id        String    @db.Uuid
  questions_done    Int       @default(0)
  questions_correct Int       @default(0)
  accuracy          Float?    @default(0)
  avg_time_spent    Float?    @default(0)
  last_attempted    DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)

  subjects subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, subject_id])
  @@index([user_id])
  @@index([subject_id])
  @@schema("public")
}

model UserOverallStat {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String    @unique @db.Uuid
  mbe_questions_done    Int       @default(0)
  mbe_questions_correct Int       @default(0)
  mbe_accuracy          Float?    @default(0)
  avg_time_spent        Float?    @default(0)
  total_sessions        Int       @default(0)
  last_attempted        DateTime? @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model StateSubjectStat {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  state             String
  subject_id        String   @db.Uuid
  questions_done    Int      @default(0)
  questions_correct Int      @default(0)
  accuracy          Float?   @default(0)
  avg_time_spent    Float?   @default(0)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  subjects subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([state, subject_id])
  @@index([state])
  @@index([subject_id])
  @@schema("public")
}

model QuestionFlag {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String    @db.Uuid
  user_id     String?   @db.Uuid
  reason      String?
  details     String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  resolved    Boolean   @default(false)
  resolved_at DateTime? @db.Timestamptz(6)

  mbe_question MBEQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([question_id])
  @@index([user_id])
  @@schema("public")
}

model QuestionRevision {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id          String   @db.Uuid
  changed_by           String?  @db.Uuid
  previous_title       String?
  previous_text        String?
  previous_answer      String?
  previous_explanation String?
  change_note          String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  mbe_question MBEQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([question_id])
  @@schema("public")
}

model user_custom_rule_progress {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  custom_rule_id   String    @db.Uuid
  success_count    Int       @default(0)
  fail_count       Int       @default(0)
  difficulty_score Float     @default(0)
  last_seen_at     DateTime? @db.Timestamptz(6)
  next_review_at   DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([user_id, custom_rule_id])
  @@index([user_id])
  @@index([custom_rule_id])
  @@schema("public")
}

model account_deletion_requests {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  email      String
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id])
  @@schema("public")
}

model announcements {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String
  body       String
  is_active  Boolean   @default(true)
  starts_at  DateTime? @db.Timestamptz(6)
  ends_at    DateTime? @db.Timestamptz(6)
  created_by String?   @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([is_active])
  @@index([starts_at])
  @@index([ends_at])
  @@schema("public")
}

model admin_notes {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id     String    @db.Uuid
  title         String?
  body          String
  priority      String    @default("normal")
  status        String    @default("open")
  audience      String    @default("all_admins")
  recipient_ids String[]  @default([])
  confidential  Boolean   @default(false)
  assignee_id   String?   @db.Uuid
  due_at        DateTime? @db.Timestamptz(6)
  is_pinned     Boolean   @default(false)
  checked_by    String[]  @default([])
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([author_id])
  @@index([assignee_id])
  @@index([is_pinned])
  @@index([priority])
  @@index([status])
  @@index([confidential])
  @@schema("public")
}

model admin_note_comments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  note_id    String   @db.Uuid
  author_id  String   @db.Uuid
  body       String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([note_id])
  @@index([author_id])
  @@schema("public")
}

model admin_note_reactions {
