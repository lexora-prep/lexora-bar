generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model user_legal_acceptances {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String    @db.Uuid
  email                   String
  terms_accepted          Boolean   @default(false)
  privacy_accepted        Boolean   @default(false)
  refund_accepted         Boolean   @default(false)
  platform_rules_accepted Boolean   @default(false)
  terms_version           String    @default("2026-05-04")
  privacy_version         String    @default("2026-05-04")
  refund_version          String    @default("2026-05-04")
  selected_plan           String?
  registration_mode       String?
  user_agent              String?
  ip_address              String?
  accepted_at             DateTime  @default(now()) @db.Timestamptz(6)
  ip_country              String?
  ip_region               String?
  ip_city                 String?
  ip_timezone             String?
  ip_latitude             Float?
  ip_longitude            Float?
  ip_lookup_provider      String?
  ip_lookup_at            DateTime? @db.Timestamptz(6)

  @@index([accepted_at(sort: Desc)])
  @@index([email])
  @@index([ip_city])
  @@index([ip_country])
  @@index([ip_lookup_at(sort: Desc)])
  @@index([user_id])
  @@schema("public")
}

model rules {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id                 String?                    @db.Uuid
  subtopic_id              String?                    @db.Uuid
  title                    String
  rule_text                String
  explanation              String?
  buzzwords                Json?
  cloze_template           String?
  is_active                Boolean                    @default(true)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  subject_uuid             String?                    @db.Uuid
  subject_id               String?                    @db.Uuid
  rule_type                String?
  prompt_question          String?
  application_example      String?
  common_trap              String?
  priority                 String?
  common_traps             Json?
  exam_tip                 String?
  how_to_apply             Json?
  flashcard_session_cards  flashcard_session_cards[]
  subjects                 subjects?                  @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_rules_subject")
  subtopics                subtopics?                 @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics                   topics?                    @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rule_progress       user_rule_progress[]
  user_rule_cycle_progress user_rule_cycle_progress[]
  user_rules               user_rules[]

  @@index([subtopic_id])
  @@index([topic_id])
  @@index([subject_id])
  @@index([is_active, subject_id], map: "idx_rules_active_subject")
  @@schema("public")
}

model subjects {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  order_index           Int                @default(0)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  exam_status           String             @default("core")
  show_in_rule_training Boolean            @default(true)
  show_in_analytics     Boolean            @default(true)
  mbe_questions         MBEQuestion[]
  state_subject_stats   StateSubjectStat[]
  topic_progress        TopicProgress[]
  user_subject_stats    UserSubjectStat[]
  rules                 rules[]
  topics                topics[]

  @@schema("public")
}

model subtopics {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id      String        @db.Uuid
  name          String
  order_index   Int           @default(0)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  mbe_questions MBEQuestion[]
  rules         rules[]
  topics        topics        @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rules    user_rules[]

  @@index([topic_id])
  @@schema("public")
}

model topics {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String          @db.Uuid
  name           String
  order_index    Int             @default(0)
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  mbe_questions  MBEQuestion[]
  topic_progress TopicProgress[]
  rules          rules[]
  subtopics      subtopics[]
  subjects       subjects        @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "topics_subject_fk")
  user_rules     user_rules[]

  @@index([subject_id])
  @@schema("public")
}

model user_buzzword_stats {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  rule_id       String    @db.Uuid
  buzzword      String
  times_correct Int?      @default(0)
  times_missed  Int?      @default(0)
  weak_flag     Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model user_rule_attempts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  rule_id          String    @db.Uuid
  score            Int
  missed_buzzwords Json?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  training_mode    String?   @db.VarChar(50)
  training_context String?   @db.VarChar(50)
  recall_seconds   Int?
  revealed_answer  Boolean   @default(false)
  self_reported    Boolean   @default(false)
  engine_version   String?   @db.VarChar(20)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([user_id, training_mode])
  @@index([user_id, created_at(sort: Desc)], map: "idx_user_rule_attempts_user_created")
  @@index([user_id, training_context], map: "idx_user_rule_attempts_user_context")
  @@index([user_id, rule_id, created_at(sort: Desc)], map: "idx_user_rule_attempts_user_rule_created")
  @@schema("public")
}

model user_rule_progress {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String    @db.Uuid
  rule_id                 String    @db.Uuid
  attempts                Int       @default(0)
  correct_count           Int       @default(0)
  incorrect_count         Int       @default(0)
  saved_for_review        Boolean   @default(false)
  needs_practice          Boolean   @default(false)
  mastery_level           Int       @default(0)
  last_reviewed           DateTime? @db.Timestamptz(6)
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @db.Timestamptz(6)
  last_score              Int?
  rolling_average         Decimal?  @db.Decimal
  next_review_at          DateTime? @db.Timestamptz(6)
  interval_days           Int?      @default(1)
  interval_minutes        Int?      @default(1440)
  mastery_confidence      Int       @default(0)
  learning_status         String    @default("UNTRAINED") @db.VarChar(30)
  effective_evidence      Decimal   @default(0) @db.Decimal(8, 2)
  successful_recall_count Int       @default(0)
  distinct_modes          Int       @default(0)
  engine_version          String?   @db.VarChar(20)
  rules                   rules     @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, rule_id], map: "user_rule_progress_user_rule_unique")
  @@index([rule_id])
  @@index([user_id])
  @@index([user_id, next_review_at])
  @@index([user_id, needs_practice], map: "idx_user_rule_progress_user_needs_practice")
  @@index([user_id, next_review_at], map: "idx_user_rule_progress_user_next_review")
  @@index([user_id, learning_status], map: "idx_user_rule_progress_user_status")
  @@schema("public")
}

model learning_cycles {
  id            String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                     @db.Uuid
  cycle_number  Int
  status        String                     @default("ACTIVE") @db.VarChar(20)
  started_at    DateTime                   @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?                  @db.Timestamptz(6)
  archived_at   DateTime?                  @db.Timestamptz(6)
  reset_reason  String?
  created_at    DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime                   @default(now()) @db.Timestamptz(6)
  rule_progress user_rule_cycle_progress[]

  @@unique([user_id, cycle_number], map: "learning_cycles_user_cycle_unique")
  @@index([user_id, status], map: "idx_learning_cycles_user_status")
  @@schema("public")
}

model user_rule_cycle_progress {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String          @db.Uuid
  cycle_id              String          @db.Uuid
  rule_id               String          @db.Uuid
  study_exposures       Int             @default(0)
  assessed_attempts     Int             @default(0)
  passed_assessments    Int             @default(0)
  best_assessment_score Int?
  first_studied_at      DateTime?       @db.Timestamptz(6)
  last_studied_at       DateTime?       @db.Timestamptz(6)
  first_assessed_at     DateTime?       @db.Timestamptz(6)
  last_assessed_at      DateTime?       @db.Timestamptz(6)
  covered_at            DateTime?       @db.Timestamptz(6)
  created_at            DateTime        @default(now()) @db.Timestamptz(6)
  updated_at            DateTime        @default(now()) @db.Timestamptz(6)
  cycle                 learning_cycles @relation(fields: [cycle_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rules                 rules           @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cycle_id, rule_id], map: "user_rule_cycle_progress_cycle_rule_unique")
  @@index([user_id, cycle_id], map: "idx_user_rule_cycle_progress_user_cycle")
  @@index([user_id, rule_id], map: "idx_user_rule_cycle_progress_user_rule")
  @@index([cycle_id, covered_at], map: "idx_user_rule_cycle_progress_cycle_covered")
  @@schema("public")
}

model user_rules {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String    @db.Uuid
  original_rule_id    String    @db.Uuid
  topic_id            String    @db.Uuid
  subtopic_id         String    @db.Uuid
  title               String
  rule_text           String
  explanation         String?
  buzzwords           Json?
  cloze_template      String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  subject_id          String?   @db.Uuid
  prompt_question     String?
  application_example String?
  common_trap         String?
  priority            String?
  common_traps        Json?
  exam_tip            String?
  how_to_apply        Json?
  rules               rules     @relation(fields: [original_rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtopics           subtopics @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics              topics    @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([original_rule_id])
  @@index([subtopic_id])
  @@index([topic_id])
  @@index([user_id])
  @@schema("public")
}

model flashcard_sessions {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                    @db.Uuid
  mode          String
  timed         Boolean                   @default(false)
  time_per_card Int?
  card_count    Int
  started_at    DateTime                  @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?                 @db.Timestamptz(6)
  cards         flashcard_session_cards[]

  @@index([user_id])
  @@schema("public")
}

model flashcard_session_cards {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String             @db.Uuid
  rule_id        String?            @db.Uuid
  custom_rule_id String?            @db.Uuid
  position       Int
  result         String?
  attempt_id     String?            @unique @db.Uuid
  time_spent     Int?
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  rules          rules?             @relation(fields: [rule_id], references: [id])
  session        flashcard_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([rule_id])
  @@schema("public")
}

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  mode            String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  mbeQuestions    Int       @default(0)
  ruleAttempts    Int       @default(0)
  flashcards      Int       @default(0)
  correctAnswers  Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([startedAt])
  @@index([userId, startedAt])
  @@index([userId, startedAt(sort: Desc)], map: "idx_study_session_user_started")
  @@schema("public")
}

model user {
  id           String   @id @default(cuid())
  jurisdiction String?
  createdAt    DateTime @default(now())

  @@schema("public")
}

model userRuleStat {
  id            String @id @default(cuid())
  userId        String
  ruleId        String
  attemptsTotal Int    @default(0)
  correct       Int    @default(0)
  incorrect     Int    @default(0)
  accuracy      Float?

  @@index([userId])
  @@index([ruleId])
  @@schema("public")
}

model user_mbe_attempts {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String       @db.Uuid
  question_id     String?      @db.Uuid
  is_correct      Boolean
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  selected_answer String?
  session_id      String?      @db.Uuid
  time_spent_sec  Int?
  mbe_question    MBEQuestion? @relation(fields: [question_id], references: [id], onUpdate: NoAction)
  exam_session    ExamSession? @relation(fields: [session_id], references: [id], onUpdate: NoAction)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([session_id])
  @@index([question_id])
  @@index([user_id, is_correct], map: "idx_user_mbe_attempts_user_correct")
  @@index([user_id, created_at(sort: Desc)], map: "idx_user_mbe_attempts_user_created")
  @@schema("public")
}

model StudyPlan {
  id                              String   @id @default(uuid())
  userId                          String   @unique
  startDate                       DateTime
  examDate                        DateTime
  studyWeekends                   Boolean
  dailyMBE                        Int
  dailyRules                      Int
  totalDays                       Int
  createdAt                       DateTime @default(now())
  offDates                        String[] @default([])
  ruleSet                         String   @default("core")
  onDates                         String[] @default([])
  jurisdictionCode                String   @default("UBE")
  jurisdictionName                String   @default("UBE / Uniform Current")
  examRegime                      String   @default("UBE_CURRENT")
  rulePackages                    String[] @default(["core"])
  customRulesEnabled              Boolean  @default(false)
  studyRound                      Int      @default(1)
  userManuallySelectedRulePackage Boolean  @default(false)
  updatedAt                       DateTime @default(now()) @updatedAt

  @@schema("public")
}

model beta_invites {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  email      String   @unique
  law_school String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@schema("public")
}

model profiles {
  id                                                               String                @id @db.Uuid
  email                                                            String                @unique
  full_name                                                        String?
  law_school                                                       String?
  jurisdiction                                                     String?
  exam_month                                                       Int?
  exam_year                                                        Int?
  created_at                                                       DateTime              @default(now())
  mbe_access                                                       Boolean               @default(false)
  subscription_tier                                                String?               @default("free")
  is_admin                                                         Boolean               @default(false)
  is_blocked                                                       Boolean               @default(false)
  role                                                             String                @default("user")
  updated_at                                                       DateTime              @default(now())
  compact_mode                                                     Boolean               @default(false)
  deleted_at                                                       DateTime?             @db.Timestamptz(6)
  deletion_requested_at                                            DateTime?             @db.Timestamptz(6)
  email_announcements                                              Boolean               @default(true)
  pending_deletion                                                 Boolean               @default(false)
  sound_effects                                                    Boolean               @default(false)
  study_reminders                                                  Boolean               @default(true)
  admin_role                                                       String?               @default("user")
  can_manage_announcements                                         Boolean               @default(false)
  can_manage_coupons                                               Boolean               @default(false)
  can_manage_questions                                             Boolean               @default(false)
  can_manage_rules                                                 Boolean               @default(false)
  can_manage_settings                                              Boolean               @default(false)
  can_manage_users                                                 Boolean               @default(false)
  can_view_audit_log                                               Boolean               @default(false)
  can_view_billing                                                 Boolean               @default(false)
  can_create_shared_notes                                          Boolean               @default(false)
  can_create_workspace_channels                                    Boolean               @default(false)
  can_manage_all_workspace                                         Boolean               @default(false)
  can_manage_workspace_members                                     Boolean               @default(false)
  workspace_status                                                 String                @default("online")
  can_create_workspace_polls                                       Boolean               @default(false)
  can_manage_hidden_channels                                       Boolean               @default(false)
  can_manage_workspace_channels                                    Boolean               @default(false)
  can_manage_workspace_notes                                       Boolean               @default(false)
  can_send_workspace_wake_alerts                                   Boolean               @default(false)
  can_view_workspace_member_details                                Boolean               @default(false)
  last_active_at                                                   DateTime?             @db.Timestamptz(6)
  last_login_at                                                    DateTime?             @db.Timestamptz(6)
  phone_number                                                     String?
  last_ip_address                                                  String?
  last_country                                                     String?
  last_region                                                      String?
  last_city                                                        String?
  last_timezone                                                    String?
  last_latitude                                                    Float?
  last_longitude                                                   Float?
  last_user_agent                                                  String?
  last_activity_source                                             String?
  billing_amount_cents                                             Int?
  billing_cancelled_at                                             DateTime?             @db.Timestamptz(6)
  billing_currency                                                 String?
  billing_discount_amount                                          String?
  billing_discount_code                                            String?
  billing_discount_id                                              String?
  billing_interval                                                 String?
  billing_invoice_url                                              String?
  billing_last_paid_at                                             DateTime?             @db.Timestamptz(6)
  billing_period_ends_at                                           DateTime?             @db.Timestamptz(6)
  billing_period_starts_at                                         DateTime?             @db.Timestamptz(6)
  billing_started_at                                               DateTime?             @db.Timestamptz(6)
  billing_status                                                   String?               @default("free")
  billing_tax_cents                                                Int?
  billing_total_cents                                              Int?
  paddle_customer_id                                               String?
  paddle_price_id                                                  String?
  paddle_subscription_id                                           String?
  paddle_transaction_id                                            String?
  admin_notifications_admin_notifications_actor_admin_idToprofiles admin_notifications[] @relation("admin_notifications_actor_admin_idToprofiles")
  admin_notifications_admin_notifications_admin_idToprofiles       admin_notifications[] @relation("admin_notifications_admin_idToprofiles")

  @@index([jurisdiction])
  @@index([role])
  @@index([is_admin])
  @@index([is_blocked])
  @@index([paddle_customer_id])
  @@index([paddle_subscription_id])
  @@index([billing_status])
  @@schema("public")
}

model support_tickets {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String                    @db.Uuid
  email                 String
  subject               String
  category              String                    @default("billing")
  status                String                    @default("open")
  priority              String                    @default("normal")
  created_at            DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                  @default(now()) @db.Timestamptz(6)
  assigned_admin_id     String?                   @db.Uuid
  assigned_admin_name   String?
  last_user_message_at  DateTime?                 @db.Timestamptz(6)
  last_support_reply_at DateTime?                 @db.Timestamptz(6)
  last_admin_read_at    DateTime?                 @db.Timestamptz(6)
  resolved_at           DateTime?                 @db.Timestamptz(6)
  closed_at             DateTime?                 @db.Timestamptz(6)
  sla_due_at            DateTime?                 @db.Timestamptz(6)
  messages              support_ticket_messages[]

  @@index([user_id])
  @@index([email])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([assigned_admin_id])
  @@index([closed_at(sort: Desc)])
  @@index([last_admin_read_at(sort: Desc)])
  @@index([last_support_reply_at(sort: Desc)])
  @@index([last_user_message_at(sort: Desc)])
  @@index([resolved_at(sort: Desc)])
  @@index([sla_due_at])
  @@schema("public")
}

model support_ticket_messages {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id  String          @db.Uuid
  sender     String          @default("user")
  message    String
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  ticket     support_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([created_at(sort: Desc)])
  @@schema("public")
}

model workspace_settings {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                          String   @unique @default("global")
  allow_note_creation           Boolean  @default(true)
  allow_shared_note_creation    Boolean  @default(true)
  allow_channel_creation        Boolean  @default(true)
  allow_hidden_channel_creation Boolean  @default(true)
  allow_poll_creation           Boolean  @default(true)
  allow_wake_alerts             Boolean  @default(true)
  created_at                    DateTime @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model MBEQuestion {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String?
  question_text          String
  answer_a               String
  answer_b               String
  answer_c               String
  answer_d               String
  correct_answer         String
  explanation            String?
  rule_text              String?
  subject_id             String                @db.Uuid
  topic_id               String?               @db.Uuid
  subtopic_id            String?               @db.Uuid
  track                  MBETrack              @default(CLASSIC)
  difficulty             Int?                  @default(1)
  source                 String?
  source_reference       String?
  question_status        QuestionStatus        @default(ACTIVE)
  is_active              Boolean               @default(true)
  version                Int                   @default(1)
  flagged_count          Int                   @default(0)
  created_at             DateTime              @default(now()) @db.Timestamptz(6)
  updated_at             DateTime              @default(now()) @db.Timestamptz(6)
  question_number        Int?                  @unique
  exam_session_questions ExamSessionQuestion[]
  subjects               subjects              @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subtopics              subtopics?            @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics                 topics?               @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  question_flags         QuestionFlag[]
  question_revisions     QuestionRevision[]
  user_mbe_attempts      user_mbe_attempts[]

  @@index([subject_id])
  @@index([topic_id])
  @@index([subtopic_id])
  @@index([track])
  @@index([question_status])
