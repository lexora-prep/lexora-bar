generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model rules {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id                String?                   @db.Uuid
  subtopic_id             String?                   @db.Uuid
  title                   String
  rule_text               String
  explanation             String?
  buzzwords               Json?
  cloze_template          String?
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  subject_uuid            String?                   @db.Uuid
  subject_id              String?                   @db.Uuid
  rule_type               String?
  flashcard_session_cards flashcard_session_cards[]
  subjects                subjects?                 @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_rules_subject")
  subtopics               subtopics?                @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics                  topics?                   @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rule_progress      user_rule_progress[]
  user_rules              user_rules[]

  @@index([subtopic_id])
  @@index([topic_id])
  @@schema("public")
}

model subjects {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  order_index Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  rules       rules[]
  topics      topics[]

  @@schema("public")
}

model subtopics {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic_id    String       @db.Uuid
  name        String
  order_index Int          @default(0)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  rules       rules[]
  topics      topics       @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_rules  user_rules[]

  @@index([topic_id])
  @@schema("public")
}

model topics {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id  String       @db.Uuid
  name        String
  order_index Int          @default(0)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  rules       rules[]
  subtopics   subtopics[]
  subjects    subjects     @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "topics_subject_fk")
  user_rules  user_rules[]

  @@index([subject_id])
  @@schema("public")
}

model user_buzzword_stats {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  rule_id       String    @db.Uuid
  buzzword      String
  times_correct Int?      @default(0)
  times_missed  Int?      @default(0)
  weak_flag     Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model user_rule_attempts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  rule_id          String    @db.Uuid
  score            Int
  missed_buzzwords Json?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model user_rule_progress {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  rule_id          String    @db.Uuid
  attempts         Int       @default(0)
  correct_count    Int       @default(0)
  incorrect_count  Int       @default(0)
  saved_for_review Boolean   @default(false)
  needs_practice   Boolean   @default(false)
  mastery_level    Int       @default(0)
  last_reviewed    DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  last_score       Int?
  rolling_average  Decimal?  @db.Decimal
  next_review_at   DateTime? @db.Timestamptz(6)
  interval_days    Int?      @default(1)
  rules            rules     @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, rule_id], map: "user_rule_progress_user_rule_unique")
  @@index([rule_id])
  @@index([user_id])
  @@schema("public")
}

model user_rules {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  original_rule_id String    @db.Uuid
  topic_id         String    @db.Uuid
  subtopic_id      String    @db.Uuid
  title            String
  rule_text        String
  explanation      String?
  buzzwords        Json?
  cloze_template   String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  subject_id       String?   @db.Uuid
  rules            rules     @relation(fields: [original_rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtopics        subtopics @relation(fields: [subtopic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  topics           topics    @relation(fields: [topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([original_rule_id])
  @@index([subtopic_id])
  @@index([topic_id])
  @@index([user_id])
  @@schema("public")
}

model flashcard_sessions {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                    @db.Uuid
  mode          String
  timed         Boolean                   @default(false)
  time_per_card Int?
  card_count    Int
  started_at    DateTime                  @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?                 @db.Timestamptz(6)
  cards         flashcard_session_cards[]

  @@index([user_id])
  @@schema("public")
}

model flashcard_session_cards {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String             @db.Uuid
  rule_id        String?            @db.Uuid
  custom_rule_id String?            @db.Uuid
  position       Int
  result         String?
  time_spent     Int?
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  rules          rules?             @relation(fields: [rule_id], references: [id])
  session        flashcard_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([rule_id])
  @@schema("public")
}

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  mode            String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  mbeQuestions    Int       @default(0)
  ruleAttempts    Int       @default(0)
  flashcards      Int       @default(0)
  correctAnswers  Int       @default(0)
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([startedAt])
  @@schema("public")
}

model user {
  id           String   @id @default(cuid())
  jurisdiction String?
  createdAt    DateTime @default(now())

  @@schema("public")
}

model userRuleStat {
  id            String   @id @default(cuid())
  userId        String
  ruleId        String
  attemptsTotal Int      @default(0)
  correct       Int      @default(0)
  incorrect     Int      @default(0)
  accuracy      Float?

  @@index([userId])
  @@index([ruleId])
  @@schema("public")
}
model user_mbe_attempts {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  question_id String? @db.Uuid
  is_correct Boolean
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id])
  @@schema("public")
}

model StudyPlan {
  id            String   @id @default(uuid())
  userId        String   @unique

  startDate     DateTime
  examDate      DateTime

  studyWeekends Boolean

  dailyMBE      Int
  dailyRules    Int

  totalDays     Int
  offDates String[] @default([])
  createdAt     DateTime @default(now())

  @@schema("public")
}

model beta_invites {
  id         String   @id @default(uuid())
  email      String   @unique
  law_school String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@schema("public")
}

model profiles {
  id                String   @id @db.Uuid
  email             String   @unique
  full_name         String?
  law_school        String?
  jurisdiction      String?
  exam_month        Int?
  exam_year         Int?
  mbe_access        Boolean  @default(false)
  subscription_tier String?  @default("free")
  created_at        DateTime @default(now())

  @@schema("public")
}